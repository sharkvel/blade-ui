{
    "semi": true,
    "singleQuote": true,
    "singleAttributePerLine": false,
    "htmlWhitespaceSensitivity": "css",
    "printWidth": 120,
    "plugins": ["@prettier/plugin-php", "prettier-plugin-tailwindcss", "prettier-plugin-laravel-blade"],
    "tailwindFunctions": ["clsx", "cn", "cva", "tw"],
    "tailwindStylesheet": "resources/css/app.css",
    "tabWidth": 4,
    "overrides": [
        {
            "files": "**/*.yml",
            "options": {
                "tabWidth": 2
            }
        },
        {
            "files": ["**/*.blade.php"],
            "options": {
                "parser": "blade",
                "bladeSlotNameStyle": "preserve"
            }
        }
    ]
}
